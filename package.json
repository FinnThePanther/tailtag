{
  "name": "tailtag",
  "version": "0.1.10",
  "main": "index.ts",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "sync:native-env": "node ./scripts/sync-native-env.cjs",
    "sync:native:development": "APP_ENV=development npm run sync:native-env",
    "sync:native:staging": "APP_ENV=staging npm run sync:native-env",
    "sync:native:production": "APP_ENV=production npm run sync:native-env",
    "start": "ulimit -n 65536 && CI=1 expo start",
    "start:watch": "ulimit -n 65536 && expo start",
    "android": "npm run sync:native-env && ulimit -n 65536 && node ./scripts/run-android.cjs",
    "android:watch": "npm run sync:native-env && ulimit -n 65536 && TAILTAG_WATCH=1 node ./scripts/run-android.cjs",
    "android:development": "APP_ENV=development npm run android:watch",
    "android:staging": "APP_ENV=staging npm run android",
    "android:production": "APP_ENV=production npm run android",
    "ios": "npm run sync:native-env && ulimit -n 65536 && CI=1 expo run:ios --device",
    "ios:watch": "npm run sync:native-env && ulimit -n 65536 && expo run:ios --device",
    "ios:development": "APP_ENV=development npm run ios:watch",
    "ios:staging": "APP_ENV=staging npm run ios:watch",
    "ios:production": "APP_ENV=production npm run ios",
    "web": "ulimit -n 65536 && CI=1 expo start --web",
    "web:watch": "ulimit -n 65536 && expo start --web",
    "tailtag-admin-v2:dev": "npm --prefix admin-v2 run dev",
    "tailtag-admin-v2:build": "npm --prefix admin-v2 run build",
    "tailtag-admin-v2:lint": "npm --prefix admin-v2 run lint",
    "tailtag-admin-v2:typecheck": "npm --prefix admin-v2 run typecheck",
    "tailtag-admin-v2:format": "npm --prefix admin-v2 run format",
    "doctor": "npx --cache /tmp/npm-cache expo-doctor",
    "lint": "eslint app src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run sync:native-env && expo prebuild --non-interactive",
    "prebuild:development": "APP_ENV=development npm run prebuild",
    "prebuild:staging": "APP_ENV=staging npm run prebuild",
    "prebuild:production": "APP_ENV=production npm run prebuild",
    "gen:types": "npx supabase gen types typescript --project-id rtxbvjicfxgcouufumce > /tmp/fresh-types.ts && python3 scripts/update-types.py /tmp/fresh-types.ts",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "ci:validate": "npm run doctor && npm run format:check && npm run lint && npm run typecheck",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "build:dev:all": "eas build --platform all --profile development",
    "build:staging:ios": "eas build --platform ios --profile staging",
    "build:staging:android": "eas build --platform android --profile staging",
    "build:staging:all": "eas build --platform all --profile staging",
    "build:prod:ios": "eas build --platform ios --profile production",
    "build:prod:android": "eas build --platform android --profile production",
    "build:prod:all": "eas build --platform all --profile production",
    "eas-build-pre-install": "node ./scripts/sync-native-env.cjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-menu/menu": "^2.0.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.58.0",
    "@tanstack/react-query": "^5.90.2",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-brightness": "^14.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.0",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "^15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.21",
    "expo-sharing": "^14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "p-retry": "^6.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-nfc-manager": "^3.17.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@expo/ngrok": "^4.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "~19.1.10",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsonwebtoken": "^9.0.3",
    "node": "^22.22.2",
    "prettier": "3.8.2",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager"
        ]
      }
    }
  }
}
