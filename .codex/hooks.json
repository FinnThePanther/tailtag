{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/enforce-rtk.py\"",
            "timeout": 5,
            "statusMessage": "Checking RTK command policy"
          }
        ]
      }
    ]
  }
}
