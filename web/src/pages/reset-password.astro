---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';

const supportEmail = siteConfig.links.supportEmail;
---

<Base title="Reset Password">
  <article class="flex-1 px-6 py-12 max-w-2xl mx-auto w-full">
    <h1 class="text-3xl font-bold text-foreground mb-4">Reset Your TailTag Password</h1>
    <p
      id="status-text"
      class="text-foreground/80 mb-8"
    >
      Verifying your reset link...
    </p>

    <section
      id="form-state"
      class="hidden space-y-6"
    >
      <form
        id="reset-form"
        method="post"
        class="space-y-5 rounded-lg border border-card-border bg-background-elevated p-6"
      >
        <div class="space-y-2">
          <label
            for="new-password"
            class="block text-sm font-semibold text-foreground"
          >
            New password
          </label>
          <input
            id="new-password"
            name="new-password"
            type="password"
            autocomplete="new-password"
            class="w-full rounded-md border border-card-border bg-background px-4 py-3 text-foreground outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
            placeholder="8+ chars, mixed case, number, symbol"
          />
        </div>

        <div class="space-y-2">
          <label
            for="confirm-password"
            class="block text-sm font-semibold text-foreground"
          >
            Confirm new password
          </label>
          <input
            id="confirm-password"
            name="confirm-password"
            type="password"
            autocomplete="new-password"
            class="w-full rounded-md border border-card-border bg-background px-4 py-3 text-foreground outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
            placeholder="Re-enter your new password"
          />
        </div>

        <ul
          id="password-requirements"
          class="grid gap-2 text-sm text-foreground/70 sm:grid-cols-2"
        >
          <li data-requirement="minLength">8+ characters</li>
          <li data-requirement="hasUppercase">Uppercase letter</li>
          <li data-requirement="hasLowercase">Lowercase letter</li>
          <li data-requirement="hasNumber">Number</li>
          <li data-requirement="hasSpecial">Special character</li>
        </ul>

        <p
          id="form-error"
          class="hidden text-sm text-red-300"
        >
        </p>

        <button
          id="submit-button"
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-md bg-primary px-5 py-3 font-semibold text-background hover:bg-primary-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Update password
        </button>
      </form>

      <div class="space-y-3 text-foreground/70">
        <p>Using your phone?</p>
        <a
          id="open-tailtag-link"
          href="tailtag:///reset-password"
          class="inline-flex items-center justify-center rounded-md border border-card-border px-5 py-3 font-semibold text-foreground hover:border-primary hover:text-primary"
        >
          Open TailTag
        </a>
      </div>
    </section>

    <section
      id="success-state"
      class="hidden space-y-4 rounded-lg border border-card-border bg-background-elevated p-6"
    >
      <h2 class="text-xl font-semibold text-foreground">Password updated</h2>
      <p class="text-foreground/80">
        Your password has been changed successfully. You can now sign in with your new password.
      </p>
    </section>

    <section
      id="invalid-state"
      class="hidden space-y-4"
    >
      <p class="text-foreground/80">
        This password reset link is invalid or expired. Request a new reset link from TailTag and
        use the newest email.
      </p>
      <p class="text-foreground/70">
        Need help? Contact
        <a
          href={`mailto:${supportEmail}`}
          class="text-primary hover:underline ml-1"
          >{supportEmail}</a
        >.
      </p>
    </section>
  </article>
  <Footer />
</Base>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { mapAuthError, validatePassword } from '../../../packages/auth-validation/src';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const RECOVERY_SESSION_MARKER_KEY = 'tailtag.recoverySession.readyAt';
  const RECOVERY_SESSION_TTL_MS = 30 * 60 * 1000;
  const hasSupabaseConfig = Boolean(SUPABASE_URL && SUPABASE_ANON_KEY);
  const supabase = hasSupabaseConfig
    ? createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
        auth: {
          autoRefreshToken: true,
          detectSessionInUrl: false,
          persistSession: true,
          storage: window.sessionStorage,
        },
      })
    : null;

  const statusText = document.getElementById('status-text');
  const formState = document.getElementById('form-state');
  const successState = document.getElementById('success-state');
  const invalidState = document.getElementById('invalid-state');
  const openTailTagLink = document.getElementById('open-tailtag-link');
  const resetForm = document.getElementById('reset-form');
  const passwordInput = document.getElementById('new-password');
  const confirmPasswordInput = document.getElementById('confirm-password');
  const formError = document.getElementById('form-error');
  const submitButton = document.getElementById('submit-button');
  const requirementList = document.getElementById('password-requirements');
  let pendingDeepLink: string | null = null;

  const showElement = (element: HTMLElement | null, shouldShow: boolean) => {
    if (!element) return;
    element.classList.toggle('hidden', !shouldShow);
  };

  const setStatus = (message: string) => {
    if (statusText) {
      statusText.textContent = message;
    }
  };

  const setError = (message: string | null) => {
    if (!formError) return;

    formError.textContent = message ?? '';
    formError.classList.toggle('hidden', !message);
  };

  const setSubmitting = (isSubmitting: boolean) => {
    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = isSubmitting;
      submitButton.textContent = isSubmitting ? 'Updating...' : 'Update password';
    }

    if (passwordInput instanceof HTMLInputElement) {
      passwordInput.disabled = isSubmitting;
    }

    if (confirmPasswordInput instanceof HTMLInputElement) {
      confirmPasswordInput.disabled = isSubmitting;
    }
  };

  const clearRecoveryTokensFromUrl = () => {
    window.history.replaceState(null, document.title, window.location.pathname);
  };

  const collectResetParams = () => {
    const mergedParams = new URLSearchParams();
    const searchParams = new URLSearchParams(window.location.search);
    const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ''));

    searchParams.forEach((value, key) => {
      if (value.length > 0) {
        mergedParams.set(key, value);
      }
    });

    hashParams.forEach((value, key) => {
      if (value.length > 0) {
        mergedParams.set(key, value);
      }
    });

    return mergedParams;
  };

  const renderRequirements = (password: string) => {
    const { requirements } = validatePassword(password);

    requirementList?.querySelectorAll('li[data-requirement]').forEach((element) => {
      const key = element.getAttribute('data-requirement');
      const isMet = key ? requirements[key as keyof typeof requirements] : false;

      element.classList.toggle('text-primary', isMet);
      element.classList.toggle('text-foreground/70', !isMet);
      element.textContent = `${isMet ? '✓' : '•'} ${element.textContent?.replace(/^[✓•]\s/, '')}`;
    });
  };

  const showInvalidState = () => {
    setStatus('This reset link is invalid or expired.');
    showElement(formState, false);
    showElement(successState, false);
    showElement(invalidState, true);
  };

  const clearRecoverySessionMarker = () => {
    window.sessionStorage.removeItem(RECOVERY_SESSION_MARKER_KEY);
  };

  const markRecoverySessionReady = () => {
    window.sessionStorage.setItem(RECOVERY_SESSION_MARKER_KEY, String(Date.now()));
  };

  const hasRecentRecoverySessionMarker = () => {
    const readyAt = Number(window.sessionStorage.getItem(RECOVERY_SESSION_MARKER_KEY));

    if (!Number.isFinite(readyAt) || Date.now() - readyAt > RECOVERY_SESSION_TTL_MS) {
      clearRecoverySessionMarker();
      return false;
    }

    return true;
  };

  const initializeResetSession = async () => {
    if (!supabase) {
      showInvalidState();
      return;
    }

    const resetParams = collectResetParams();
    const hasError = resetParams.has('error') || resetParams.has('error_code');
    const accessToken = resetParams.get('access_token');
    const refreshToken = resetParams.get('refresh_token');
    const isRecoveryLink = resetParams.get('type') === 'recovery';
    const isValidRecoveryLink = !hasError && isRecoveryLink && accessToken && refreshToken;
    const hasRecoveryParams =
      hasError ||
      resetParams.has('type') ||
      resetParams.has('access_token') ||
      resetParams.has('refresh_token');

    if (!isValidRecoveryLink) {
      if (hasRecoveryParams || !hasRecentRecoverySessionMarker()) {
        showInvalidState();
        return;
      }

      const {
        data: { session },
      } = await supabase.auth.getSession();

      if (session) {
        setStatus('Choose a strong new password for your account.');
        showElement(formState, true);
        showElement(successState, false);
        showElement(invalidState, false);
        return;
      }

      showInvalidState();
      return;
    }

    const deepLink = `tailtag:///reset-password?${resetParams.toString()}`;
    pendingDeepLink = deepLink;

    if (openTailTagLink instanceof HTMLAnchorElement) {
      openTailTagLink.href = deepLink;
    }

    const { error } = await supabase.auth.setSession({
      access_token: accessToken,
      refresh_token: refreshToken,
    });

    if (error) {
      showInvalidState();
      return;
    }

    clearRecoveryTokensFromUrl();
    markRecoverySessionReady();
    setStatus('Choose a strong new password for your account.');
    showElement(formState, true);
    showElement(successState, false);
    showElement(invalidState, false);
  };

  passwordInput?.addEventListener('input', () => {
    const password = passwordInput instanceof HTMLInputElement ? passwordInput.value : '';
    renderRequirements(password);
  });

  openTailTagLink?.addEventListener('click', (event) => {
    if (!pendingDeepLink) {
      return;
    }

    event.preventDefault();
    window.location.assign(pendingDeepLink);
  });

  resetForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!supabase) {
      setError('Password reset is unavailable. Please try again later.');
      return;
    }

    const password = passwordInput instanceof HTMLInputElement ? passwordInput.value : '';
    const confirmPassword =
      confirmPasswordInput instanceof HTMLInputElement ? confirmPasswordInput.value : '';
    const validation = validatePassword(password);

    if (!validation.isAcceptable) {
      setError("Your new password doesn't meet all the requirements shown below.");
      return;
    }

    if (password !== confirmPassword) {
      setError('Passwords do not match.');
      return;
    }

    setSubmitting(true);
    setError(null);

    try {
      const { error } = await supabase.auth.updateUser({
        password,
      });

      if (error) {
        throw error;
      }

      await supabase.auth.signOut({ scope: 'local' });
      clearRecoverySessionMarker();
      setStatus('Password updated.');
      showElement(formState, false);
      showElement(successState, true);
      showElement(invalidState, false);
    } catch (caught) {
      setError(mapAuthError(caught));
    } finally {
      setSubmitting(false);
    }
  });

  renderRequirements('');
  void initializeResetSession();
</script>
