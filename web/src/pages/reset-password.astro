---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';

const supportEmail = siteConfig.links.supportEmail;
---

<Base title="Reset Password">
  <article class="flex-1 px-6 py-12 max-w-2xl mx-auto w-full">
    <h1 class="text-3xl font-bold text-foreground mb-4">Reset Your TailTag Password</h1>
    <p
      id="status-text"
      class="text-foreground/80 mb-8"
    >
      Verifying your reset link...
    </p>

    <section
      id="form-state"
      class="hidden space-y-6"
    >
      <form
        id="reset-form"
        method="post"
        class="space-y-5 rounded-lg border border-card-border bg-background-elevated p-6"
      >
        <div class="space-y-2">
          <label
            for="new-password"
            class="block text-sm font-semibold text-foreground"
          >
            New password
          </label>
          <input
            id="new-password"
            name="new-password"
            type="password"
            autocomplete="new-password"
            class="w-full rounded-md border border-card-border bg-background px-4 py-3 text-foreground outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
            placeholder="8+ chars, mixed case, number, symbol"
          />
        </div>

        <div class="space-y-2">
          <label
            for="confirm-password"
            class="block text-sm font-semibold text-foreground"
          >
            Confirm new password
          </label>
          <input
            id="confirm-password"
            name="confirm-password"
            type="password"
            autocomplete="new-password"
            class="w-full rounded-md border border-card-border bg-background px-4 py-3 text-foreground outline-none focus:border-primary focus:ring-2 focus:ring-primary/30"
            placeholder="Re-enter your new password"
          />
        </div>

        <ul
          id="password-requirements"
          class="grid gap-2 text-sm text-foreground/70 sm:grid-cols-2"
        >
          <li data-requirement="minLength">8+ characters</li>
          <li data-requirement="hasUppercase">Uppercase letter</li>
          <li data-requirement="hasLowercase">Lowercase letter</li>
          <li data-requirement="hasNumber">Number</li>
          <li data-requirement="hasSpecial">Special character</li>
        </ul>

        <p
          id="form-error"
          class="hidden text-sm text-red-300"
        >
        </p>

        <button
          id="submit-button"
          type="submit"
          class="inline-flex w-full items-center justify-center rounded-md bg-primary px-5 py-3 font-semibold text-background hover:bg-primary-dark focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60 disabled:cursor-not-allowed disabled:opacity-60"
        >
          Update password
        </button>
      </form>
    </section>

    <section
      id="success-state"
      class="hidden space-y-4 rounded-lg border border-card-border bg-background-elevated p-6"
    >
      <h2 class="text-xl font-semibold text-foreground">Password updated</h2>
      <p class="text-foreground/80">
        Your password has been changed successfully. You can now sign in with your new password.
      </p>
    </section>

    <section
      id="invalid-state"
      class="hidden space-y-4"
    >
      <p class="text-foreground/80">
        This password reset link is invalid or expired. Request a new reset link from TailTag and
        use the newest email.
      </p>
      <p class="text-foreground/70">
        Need help? Contact
        <a
          href={`mailto:${supportEmail}`}
          class="text-primary hover:underline ml-1"
          >{supportEmail}</a
        >.
      </p>
    </section>
  </article>
  <Footer />
</Base>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { mapAuthError, validatePassword } from '../../../packages/auth-validation/src';

  const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const SUPABASE_PROJECTS: Record<string, { projectRef: string; url: string; anonKey: string }> = {
    rtxbvjicfxgcouufumce: {
      projectRef: 'rtxbvjicfxgcouufumce',
      url: 'https://rtxbvjicfxgcouufumce.supabase.co',
      anonKey:
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ0eGJ2amljZnhnY291dWZ1bWNlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTkxOTA1MDgsImV4cCI6MjA3NDc2NjUwOH0.5YA3PLhJqbek_Z8cf8CaRXJNZjl2ZvCSnkVpNrtLGww',
    },
    yjsadmswobafychfpoxe: {
      projectRef: 'yjsadmswobafychfpoxe',
      url: 'https://yjsadmswobafychfpoxe.supabase.co',
      anonKey:
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlqc2FkbXN3b2JhZnljaGZwb3hlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyMzczMjMsImV4cCI6MjA5MDgxMzMyM30.MDrOcAvO3fg1AOVZym-xXl3txtlkDnm4O8YNjTZihuI',
    },
    dowtlhkzbxxmiflpswvd: {
      projectRef: 'dowtlhkzbxxmiflpswvd',
      url: 'https://dowtlhkzbxxmiflpswvd.supabase.co',
      anonKey:
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRvd3RsaGt6Ynh4bWlmbHBzd3ZkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUyMzc2MjIsImV4cCI6MjA5MDgxMzYyMn0.KIw5TF-tBq3NIKjpzkNGagLR0jwiYKP_s7RqchEhXHo',
    },
  };
  const RECOVERY_SUCCESS_MARKER_KEY = 'tailtag.recoverySession.completedAt';
  const RECOVERY_SESSION_TTL_MS = 30 * 60 * 1000;
  const createResetSupabaseClient = (url: string, anonKey: string) => {
    return createClient(url, anonKey, {
      auth: {
        autoRefreshToken: true,
        detectSessionInUrl: false,
        persistSession: true,
        storage: window.sessionStorage,
      },
    });
  };
  type ResetSupabaseClient = ReturnType<typeof createResetSupabaseClient>;
  type SupabaseProjectConfig = (typeof SUPABASE_PROJECTS)[keyof typeof SUPABASE_PROJECTS];
  type PendingTokenHashReset = {
    tokenHash: string;
    params: URLSearchParams;
  };
  const getProjectRefFromUrl = (url: string | undefined) => {
    if (!url) return null;

    try {
      return new URL(url).hostname.split('.')[0] ?? null;
    } catch {
      return null;
    }
  };
  const fallbackSupabaseConfig =
    SUPABASE_URL && SUPABASE_ANON_KEY
      ? {
          projectRef: getProjectRefFromUrl(SUPABASE_URL) ?? 'default',
          url: SUPABASE_URL,
          anonKey: SUPABASE_ANON_KEY,
        }
      : null;
  const fallbackProjectRef = getProjectRefFromUrl(SUPABASE_URL);

  const statusText = document.getElementById('status-text');
  const formState = document.getElementById('form-state');
  const successState = document.getElementById('success-state');
  const invalidState = document.getElementById('invalid-state');
  const resetForm = document.getElementById('reset-form');
  const passwordInput = document.getElementById('new-password');
  const confirmPasswordInput = document.getElementById('confirm-password');
  const formError = document.getElementById('form-error');
  const submitButton = document.getElementById('submit-button');
  const requirementList = document.getElementById('password-requirements');
  let activeSupabase: ResetSupabaseClient | null = null;
  let pendingTokenHashReset: PendingTokenHashReset | null = null;

  const showElement = (element: HTMLElement | null, shouldShow: boolean) => {
    if (!element) return;
    element.classList.toggle('hidden', !shouldShow);
  };

  const setStatus = (message: string) => {
    if (statusText) {
      statusText.textContent = message;
    }
  };

  const setError = (message: string | null) => {
    if (!formError) return;

    formError.textContent = message ?? '';
    formError.classList.toggle('hidden', !message);
  };

  const setSubmitting = (isSubmitting: boolean) => {
    if (submitButton instanceof HTMLButtonElement) {
      submitButton.disabled = isSubmitting;
      submitButton.textContent = isSubmitting ? 'Updating...' : 'Update password';
    }

    if (passwordInput instanceof HTMLInputElement) {
      passwordInput.disabled = isSubmitting;
    }

    if (confirmPasswordInput instanceof HTMLInputElement) {
      confirmPasswordInput.disabled = isSubmitting;
    }
  };

  const clearRecoveryTokensFromUrl = () => {
    window.history.replaceState(null, document.title, window.location.pathname);
  };

  const collectResetParams = () => {
    const mergedParams = new URLSearchParams();
    const searchParams = new URLSearchParams(window.location.search);
    const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ''));

    searchParams.forEach((value, key) => {
      if (value.length > 0) {
        mergedParams.set(key, value);
      }
    });

    hashParams.forEach((value, key) => {
      if (value.length > 0) {
        mergedParams.set(key, value);
      }
    });

    return mergedParams;
  };

  const renderRequirements = (password: string) => {
    const { requirements } = validatePassword(password);

    requirementList?.querySelectorAll('li[data-requirement]').forEach((element) => {
      const key = element.getAttribute('data-requirement');
      const isMet = key ? requirements[key as keyof typeof requirements] : false;

      element.classList.toggle('text-primary', isMet);
      element.classList.toggle('text-foreground/70', !isMet);
      element.textContent = `${isMet ? '✓' : '•'} ${element.textContent?.replace(/^[✓•]\s/, '')}`;
    });
  };

  const showFormState = () => {
    setStatus('Choose a strong new password for your account.');
    showElement(formState, true);
    showElement(successState, false);
    showElement(invalidState, false);
  };

  const showInvalidState = () => {
    setStatus('This reset link is invalid or expired.');
    showElement(formState, false);
    showElement(successState, false);
    showElement(invalidState, true);
  };

  const clearRecoverySuccessMarker = () => {
    window.sessionStorage.removeItem(RECOVERY_SUCCESS_MARKER_KEY);
  };

  const markRecoverySuccess = () => {
    window.sessionStorage.setItem(RECOVERY_SUCCESS_MARKER_KEY, String(Date.now()));
  };

  const hasRecentRecoveryMarker = (key: string) => {
    const readyAt = Number(window.sessionStorage.getItem(key));

    if (!Number.isFinite(readyAt) || Date.now() - readyAt > RECOVERY_SESSION_TTL_MS) {
      window.sessionStorage.removeItem(key);
      return false;
    }

    return true;
  };

  const hasRecentRecoverySuccessMarker = () => {
    return hasRecentRecoveryMarker(RECOVERY_SUCCESS_MARKER_KEY);
  };

  const showSuccessState = () => {
    setStatus('Password updated.');
    showElement(formState, false);
    showElement(successState, true);
    showElement(invalidState, false);
  };

  const dedupeProjectConfigs = (configs: Array<SupabaseProjectConfig | null | undefined>) => {
    const seenProjectRefs = new Set<string>();
    const deduped: SupabaseProjectConfig[] = [];

    configs.forEach((config) => {
      if (!config || seenProjectRefs.has(config.projectRef)) {
        return;
      }

      seenProjectRefs.add(config.projectRef);
      deduped.push(config);
    });

    return deduped;
  };

  const getProjectConfigsForParams = (params: URLSearchParams) => {
    const requestedProjectRef = params.get('project_ref');
    const requestedProject = requestedProjectRef ? SUPABASE_PROJECTS[requestedProjectRef] : null;
    const fallbackProject = fallbackProjectRef ? SUPABASE_PROJECTS[fallbackProjectRef] : null;
    const projectConfigs = Object.values(SUPABASE_PROJECTS);

    if (requestedProjectRef) {
      return dedupeProjectConfigs([requestedProject]);
    }

    return dedupeProjectConfigs([
      fallbackProject,
      fallbackSupabaseConfig,
      ...projectConfigs.filter((config) => config.projectRef !== fallbackProjectRef),
    ]);
  };

  const getPreferredSupabaseClient = (params: URLSearchParams) => {
    const [config] = getProjectConfigsForParams(params);

    return config ? createResetSupabaseClient(config.url, config.anonKey) : null;
  };

  const verifyPendingTokenHashReset = async () => {
    if (!pendingTokenHashReset) {
      return activeSupabase;
    }

    let lastError: unknown = null;
    const configs = getProjectConfigsForParams(pendingTokenHashReset.params);

    for (const config of configs) {
      const resetSupabase = createResetSupabaseClient(config.url, config.anonKey);
      const { error } = await resetSupabase.auth.verifyOtp({
        token_hash: pendingTokenHashReset.tokenHash,
        type: 'recovery',
      });

      if (!error) {
        activeSupabase = resetSupabase;
        pendingTokenHashReset = null;
        clearRecoveryTokensFromUrl();
        return resetSupabase;
      }

      lastError = error;
    }

    throw lastError ?? new Error('Password reset link is invalid or expired.');
  };

  const initializeResetSession = async () => {
    const resetParams = collectResetParams();
    const resetSupabase = getPreferredSupabaseClient(resetParams);
    activeSupabase = null;
    pendingTokenHashReset = null;

    const hasError = resetParams.has('error') || resetParams.has('error_code');
    const code = resetParams.get('code');
    const tokenHash = resetParams.get('token_hash');
    const accessToken = resetParams.get('access_token');
    const refreshToken = resetParams.get('refresh_token');
    const isRecoveryLink = resetParams.get('type') === 'recovery';
    const hasRecoveryCode = !hasError && Boolean(code);
    const hasRecoveryTokenHash = !hasError && isRecoveryLink && Boolean(tokenHash);
    const hasRecoveryTokens =
      !hasError && isRecoveryLink && Boolean(accessToken) && Boolean(refreshToken);
    const isValidRecoveryLink = hasRecoveryCode || hasRecoveryTokenHash || hasRecoveryTokens;
    const hasRecoveryParams =
      hasError ||
      resetParams.has('code') ||
      resetParams.has('token_hash') ||
      resetParams.has('type') ||
      resetParams.has('access_token') ||
      resetParams.has('refresh_token');

    if (!isValidRecoveryLink) {
      if (!hasRecoveryParams && hasRecentRecoverySuccessMarker()) {
        showSuccessState();
        return;
      }

      if (hasRecoveryParams || !resetSupabase) {
        showInvalidState();
        return;
      }

      const {
        data: { session },
      } = await resetSupabase.auth.getSession();

      if (session) {
        activeSupabase = resetSupabase;
        showFormState();
        return;
      }

      showInvalidState();
      return;
    }

    clearRecoverySuccessMarker();

    if (hasRecoveryTokenHash) {
      pendingTokenHashReset = {
        tokenHash: tokenHash as string,
        params: new URLSearchParams(resetParams),
      };
      showFormState();
      return;
    }

    if (!resetSupabase) {
      showInvalidState();
      return;
    }

    const { error } = hasRecoveryCode
      ? await resetSupabase.auth.exchangeCodeForSession(code as string)
      : await resetSupabase.auth.setSession({
          access_token: accessToken as string,
          refresh_token: refreshToken as string,
        });

    if (error) {
      showInvalidState();
      return;
    }

    activeSupabase = resetSupabase;

    clearRecoveryTokensFromUrl();
    showFormState();
  };

  passwordInput?.addEventListener('input', () => {
    const password = passwordInput instanceof HTMLInputElement ? passwordInput.value : '';
    renderRequirements(password);
  });

  resetForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const password = passwordInput instanceof HTMLInputElement ? passwordInput.value : '';
    const confirmPassword =
      confirmPasswordInput instanceof HTMLInputElement ? confirmPasswordInput.value : '';
    const validation = validatePassword(password);

    if (!validation.isAcceptable) {
      setError("Your new password doesn't meet all the requirements shown below.");
      return;
    }

    if (password !== confirmPassword) {
      setError('Passwords do not match.');
      return;
    }

    setSubmitting(true);
    setError(null);

    try {
      const resetSupabase = await verifyPendingTokenHashReset();

      if (!resetSupabase) {
        throw new Error('Password reset is unavailable. Please request a new reset link.');
      }

      const { error } = await resetSupabase.auth.updateUser({
        password,
      });

      if (error) {
        throw error;
      }

      await resetSupabase.auth.signOut({ scope: 'local' });
      markRecoverySuccess();
      clearRecoveryTokensFromUrl();
      showSuccessState();
    } catch (caught) {
      setError(mapAuthError(caught));
    } finally {
      setSubmitting(false);
    }
  });

  renderRequirements('');
  void initializeResetSession();
</script>
