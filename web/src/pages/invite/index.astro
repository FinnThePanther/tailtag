---
import Base from '../../layouts/Base.astro';
import { siteConfig } from '../../config/site';

const { appStore, playStore } = siteConfig.links;
---

<Base
  title="TailTag invite"
  description="Open TailTag to review an invite catch."
>
  <main class="invite-page">
    <section class="invite-panel">
      <p class="eyebrow">TailTag invite</p>
      <h1>You were tagged on TailTag</h1>
      <p>
        Open TailTag to review the photo, choose your fursuit, and approve the catch if it is you.
      </p>
      <div class="actions">
        <a
          id="open-tailtag-link"
          class="primary"
          href="tailtag://"
        >
          Open TailTag
        </a>
        <a
          id="get-app-link"
          class="secondary"
          href="/#download"
        >
          Get the app
        </a>
      </div>
    </section>
  </main>
</Base>

<script define:vars={{ appStore, playStore }}>
  const openLink = document.getElementById('open-tailtag-link');
  const getAppLink = document.getElementById('get-app-link');
  const inviteMatch = window.location.pathname.match(/\/invite\/([^/?#]+)/);
  const token = inviteMatch?.[1];

  if (openLink instanceof HTMLAnchorElement && token) {
    try {
      openLink.href = `tailtag://invite/${encodeURIComponent(decodeURIComponent(token))}`;
    } catch {
      openLink.href = 'tailtag://';
    }
  }

  if (getAppLink instanceof HTMLAnchorElement) {
    const userAgent = navigator.userAgent;
    const isIOS =
      /iPad|iPhone|iPod/.test(userAgent) ||
      (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
    const isAndroid = /Android/.test(userAgent);

    if (isIOS) {
      getAppLink.href = appStore;
    } else if (isAndroid) {
      getAppLink.href = playStore;
    }
  }
</script>

<style>
  .invite-page {
    min-height: 70vh;
    display: grid;
    place-items: center;
    padding: 4rem 1.5rem;
  }

  .invite-panel {
    width: min(100%, 34rem);
    display: grid;
    gap: 1rem;
  }

  .eyebrow {
    margin: 0;
    color: #7c3aed;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: #f8fafc;
    font-size: clamp(2rem, 8vw, 3.5rem);
    line-height: 1;
  }

  p {
    margin: 0;
    color: #cbd5e1;
    font-size: 1rem;
    line-height: 1.6;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  a {
    min-height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    padding: 0 1rem;
    font-weight: 800;
    text-decoration: none;
  }

  .primary {
    background: #7c3aed;
    color: #fff;
  }

  .secondary {
    border: 1px solid rgba(148, 163, 184, 0.35);
    color: #f8fafc;
  }
</style>
