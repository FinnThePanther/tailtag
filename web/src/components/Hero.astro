---
import { siteConfig } from '../config/site';
import Platforms from './Platforms.astro';
---

<section class="flex-1 flex flex-col items-center justify-center px-6 py-16 text-center">
  <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">
    {siteConfig.name}
  </h1>
  <p class="text-lg sm:text-xl text-foreground/80 max-w-md mb-8">
    {siteConfig.tagline}
  </p>
  <Platforms />
</section>
