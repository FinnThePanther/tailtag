---
import { siteConfig } from '../config/site';
import Platforms from './Platforms.astro';
---

<section class="flex-1 flex flex-col items-center justify-center px-6 py-16 text-center">
  <img
    src="/tailtag-icon-320-v1.png"
    srcset="/tailtag-icon-160-v1.png 160w, /tailtag-icon-320-v1.png 320w, /tailtag-icon-480-v1.png 480w"
    sizes="(min-width: 640px) 144px, 112px"
    alt="TailTag logo"
    width="160"
    height="160"
    decoding="async"
    fetchpriority="high"
    class="mb-6 h-28 w-28 rounded-3xl sm:h-36 sm:w-36"
  />
  <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground mb-4">
    {siteConfig.name}
  </h1>
  <p class="text-lg sm:text-xl text-foreground/80 max-w-md mb-8">
    {siteConfig.tagline}
  </p>
  <Platforms />
</section>
