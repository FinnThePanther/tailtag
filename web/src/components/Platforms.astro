---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../config/site';

const { ios, android } = siteConfig.platforms;
const { ios: iosLink, android: androidLink } = siteConfig.links;
---

<div class="flex flex-col sm:flex-row gap-4 w-full max-w-sm">
  {
    ios && (
      <a
        href={iosLink}
        class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 bg-foreground text-background font-semibold rounded-xl hover:bg-foreground/90 transition-colors min-h-[52px]"
      >
        <Icon
          name="simple-icons:apple"
          class="w-6 h-6"
        />
        <span>iOS TestFlight</span>
      </a>
    )
  }
  {
    android && (
      <a
        href={androidLink}
        class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 bg-primary text-background font-semibold rounded-xl hover:bg-primary-dark transition-colors min-h-[52px]"
      >
        <Icon
          name="simple-icons:android"
          class="w-6 h-6"
        />
        <span>Android APK</span>
      </a>
    )
  }
</div>
