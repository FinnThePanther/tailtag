#!/bin/sh
# Regenerates src/types/database.ts when migration files are staged,
# then re-stages the file so the commit stays consistent.

if ! git diff --cached --name-only | grep -q '^supabase/migrations/'; then
  exit 0
fi

echo "Migration files staged — syncing database types..."

if [ -z "$SUPABASE_ACCESS_TOKEN" ]; then
  echo "ERROR: SUPABASE_ACCESS_TOKEN is not set. Run 'npm run gen:types' manually, then commit again."
  exit 1
fi

npm run gen:types --silent
git add src/types/database.ts
echo "database.ts updated and staged."
